# Required: create a real API key for the AI mediation worker.
OPENAI_API_KEY=replace-with-a-valid-openai-api-key

# PostgreSQL settings used by the local/demo Compose stack.
POSTGRES_DB=twotalk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-database-password

# Change these development placeholders before sharing a running environment.
SESSION_TOKEN_SECRET=replace-with-a-long-random-session-secret
INVITATION_TOKEN_SECRET=replace-with-a-different-long-random-invitation-secret

# Optional provider and worker tuning.
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=2000
AI_JOB_LEASE_SECONDS=60
AI_JOB_POLL_INTERVAL_SECONDS=1
AI_ATTEMPT_STALE_SECONDS=60

# Optional published host ports. Internal container ports do not change.
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Internal Vite development proxy target used inside Compose.
VITE_API_PROXY_TARGET=http://backend:8000
