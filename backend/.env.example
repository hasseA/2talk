APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/twotalk
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=2000
AI_JOB_LEASE_SECONDS=60
AI_JOB_POLL_INTERVAL_SECONDS=1
AI_ATTEMPT_STALE_SECONDS=60
SESSION_TOKEN_SECRET=replace-with-a-long-random-development-secret
INVITATION_TOKEN_SECRET=replace-with-a-different-long-random-development-secret
